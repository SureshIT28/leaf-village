class Node:
    def __init__(self, value):
        self.value = value
        self.left = None
        self.right = None

# Create tree
root = Node(1)
root.left = Node(2)
root.right = Node(3)

print(root.value)
print(root.left.value)
print(root.right.value)
print(root.left.left)
n = 5

# Top
for i in range(1, n + 1):
    print(" " * (n - i) + "* " * (2 * i - 1))

# Trunk
print(" " * (n - 1) + "|")